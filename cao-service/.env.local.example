# Copy to .env.local and fill in real values — NEVER commit .env.local to git

# Supabase — from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx

# LINE Messaging API — from LINE Developers Console → Messaging API channel
LINE_CHANNEL_ACCESS_TOKEN=your-channel-long-lived-token

# LINE group/room ID for manager new-job alerts (optional)
LINE_MANAGER_GROUP_ID=C_your_group_or_room_id
